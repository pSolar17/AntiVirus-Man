[node name="Control" type="Control" parent="CanvasLayer/Control"]
anchors_preset = 0
offset_right = 640.0
offset_bottom = 360.0

[node name="Label" type="Label" parent="CanvasLayer/Control/Control"]
layout_mode = 0
offset_left = 32.0
offset_top = 32.0
offset_right = 608.0
offset_bottom = 64.0
text = "LONG TIME AGO, IN A GALAXY FAR, FAR AWAY..."
vertical_alignment = 1
visible_characters = 0
visible_ratio = 0.0

[node name="Label2" type="Label" parent="CanvasLayer/Control/Control"]
layout_mode = 0
offset_left = 32.0
offset_top = 64.0
offset_right = 608.0
offset_bottom = 96.0
text = "... A VIRUS UNLIKE ANY OTHER WAS BORN."
vertical_alignment = 1
visible_characters = 0
visible_ratio = 0.0

[node name="Label3" type="Label" parent="CanvasLayer/Control/Control"]
layout_mode = 0
offset_left = 32.0
offset_top = 96.0
offset_right = 608.0
offset_bottom = 128.0
text = "IT SPREAD AND MULTIPLIED WITHOUT CONTROL..."
vertical_alignment = 1
visible_characters = 0
visible_ratio = 0.0

[node name="Label4" type="Label" parent="CanvasLayer/Control/Control"]
layout_mode = 0
offset_left = 32.0
offset_top = 128.0
offset_right = 608.0
offset_bottom = 160.0
text = "... AND CONQUERED SPACE."
vertical_alignment = 1
visible_characters = 0
visible_ratio = 0.0

[node name="Label5" type="Label" parent="CanvasLayer/Control/Control"]
layout_mode = 0
offset_left = 32.0
offset_top = 160.0
offset_right = 608.0
offset_bottom = 192.0
text = "THOSE WHO SURVIVED LOST THEIR HOPE..."
vertical_alignment = 1
visible_characters = 0
visible_ratio = 0.0

[node name="Label6" type="Label" parent="CanvasLayer/Control/Control"]
layout_mode = 0
offset_left = 32.0
offset_top = 192.0
offset_right = 608.0
offset_bottom = 224.0
text = "... AND PRAYED IN SHELTERS FOR SALVATION."
vertical_alignment = 1
visible_characters = 0
visible_ratio = 0.0

[node name="Control2" type="Control" parent="CanvasLayer/Control"]
anchors_preset = 0
offset_right = 640.0
offset_bottom = 360.0

[node name="Label" type="Label" parent="CanvasLayer/Control/Control2"]
layout_mode = 0
offset_left = 32.0
offset_top = 32.0
offset_right = 608.0
offset_bottom = 64.0
text = "THEN, ONE DAY..."
vertical_alignment = 1
visible_characters = 0
visible_ratio = 0.0

[node name="Label2" type="Label" parent="CanvasLayer/Control/Control2"]
layout_mode = 0
offset_left = 32.0
offset_top = 64.0
offset_right = 608.0
offset_bottom = 96.0
text = ".... A HERO UNKNOWN WAS SPOTTED ON THE GALAXY'S EDGE."
vertical_alignment = 1
visible_characters = 0
visible_ratio = 0.0

[node name="Label3" type="Label" parent="CanvasLayer/Control/Control2"]
layout_mode = 0
offset_left = 32.0
offset_top = 96.0
offset_right = 608.0
offset_bottom = 128.0
text = "HE FENDED OFF THE HORDES OF ENEMIES..."
vertical_alignment = 1
visible_characters = 0
visible_ratio = 0.0

[node name="Label4" type="Label" parent="CanvasLayer/Control/Control2"]
layout_mode = 0
offset_left = 32.0
offset_top = 128.0
offset_right = 608.0
offset_bottom = 160.0
text = "... AND PROTECTED THOSE IN DANGER."
vertical_alignment = 1
visible_characters = 0
visible_ratio = 0.0

[node name="Label5" type="Label" parent="CanvasLayer/Control/Control2"]
layout_mode = 0
offset_left = 32.0
offset_top = 160.0
offset_right = 608.0
offset_bottom = 192.0
text = "HIS RESOLVE, BRIGTHER THAN A THOUSAND STARS."
vertical_alignment = 1
visible_characters = 0
visible_ratio = 0.0

[node name="Label6" type="Label" parent="CanvasLayer/Control/Control2"]
layout_mode = 0
offset_left = 32.0
offset_top = 192.0
offset_right = 608.0
offset_bottom = 224.0
text = "HIS BRAWN, WORTHY OF A GOD."
vertical_alignment = 1
visible_characters = 0
visible_ratio = 0.0

[node name="Label7" type="Label" parent="CanvasLayer/Control/Control2"]
layout_mode = 0
offset_left = 32.0
offset_top = 224.0
offset_right = 608.0
offset_bottom = 256.0
text = "AND HIS NAME WAS..."
vertical_alignment = 1
visible_characters = 0
visible_ratio = 0.0

