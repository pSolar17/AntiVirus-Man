[sub_resource type="GDScript" id="GDScript_pmhft"]
script/source = "extends Enemy

func _physics_process(delta: float) -> void:
	pass

func _input(event: InputEvent) -> void:
	if $Timer.time_left > 0.0:
		return
	
	if event.is_action_pressed(\"Down\") or event.is_action_pressed(\"Left\") or event.is_action_pressed(\"Up\") or event.is_action_pressed(\"Right\"):
		die()
"

